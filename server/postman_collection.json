{
  "info": {
    "name": "Template Gestionale API",
    "description": "Collection per testare le API del backend Express.\n\nCome usarla:\n1. Postman → File → Import → seleziona questo file.\n2. La variabile `baseUrl` punta a http://localhost:3000: per testare il deploy cambiala con il dominio Railway (tab Variables della collection).\n3. Esegui `Auth / Login`: il token JWT viene salvato automaticamente nella variabile `token` e usato da tutte le rotte protette.\n\nCredenziali di test (create da `npm run seed`): admin@test.it / Admin123! — utente@test.it / Utente123!\n\nQuando aggiungi una risorsa al progetto, aggiungi qui la sua cartella di richieste (vedi ADDING_A_RESOURCE.md).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.ok && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token salvato nella variabile {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Mario\",\n    \"last_name\": \"Rossi\",\n    \"email\": \"mario.rossi@test.it\",\n    \"password\": \"Password123!\",\n    \"repeatPassword\": \"Password123!\",\n    \"isAdmin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registrazione pubblica. Salva automaticamente il token restituito."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.ok && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token salvato nella variabile {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@test.it\",\n    \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login. Salva automaticamente il token nella variabile della collection: le altre richieste lo usano via Bearer."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Dati dell'utente autenticato (dal token). Protetta."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout stateless: risponde ok, l'invalidazione del token è a carico del client."
          }
        }
      ]
    },
    {
      "name": "Users (solo admin)",
      "description": "Tutte le rotte richiedono token di un utente admin (fai prima Login con admin@test.it).",
      "item": [
        {
          "name": "Lista utenti",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Dettaglio utente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'utente" }]
            }
          }
        },
        {
          "name": "Crea utente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Luigi\",\n    \"last_name\": \"Verdi\",\n    \"email\": \"luigi.verdi@test.it\",\n    \"password\": \"Password123!\",\n    \"isAdmin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Aggiorna utente",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Luigi\",\n    \"last_name\": \"Verdi\",\n    \"email\": \"luigi.verdi@test.it\",\n    \"isAdmin\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'utente" }]
            },
            "description": "password opzionale: aggiungerla al body solo per cambiarla."
          }
        },
        {
          "name": "Elimina utente",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'utente" }]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "description": "Lista e dettaglio accessibili a qualsiasi utente autenticato (un dipendente vede solo i corsi a lui assegnati). Le altre rotte richiedono un admin.",
      "item": [
        {
          "name": "Lista corsi",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "Dettaglio corso",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["courses", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid del corso" }]
            }
          }
        },
        {
          "name": "Crea corso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Sicurezza sul lavoro D.Lgs 81/08\",\n    \"description\": \"Corso base sulla sicurezza in azienda, aggiornamento 2026.\",\n    \"category\": \"Compliance\",\n    \"duration_hours\": 4,\n    \"mandatory\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses",
              "host": ["{{baseUrl}}"],
              "path": ["courses"]
            },
            "description": "Solo admin. title (2-200), category (2-100), duration_hours (intero positivo) e mandatory (booleano) sono obbligatori; description (2-1000) è opzionale. I campi testuali ammettono cifre e punteggiatura. 409 se il titolo è già in uso."
          }
        },
        {
          "name": "Aggiorna corso",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Sicurezza sul lavoro D.Lgs 81/08\",\n    \"description\": \"Corso base sulla sicurezza in azienda, aggiornamento 2026.\",\n    \"category\": \"Compliance\",\n    \"duration_hours\": 6,\n    \"mandatory\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/courses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["courses", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid del corso" }]
            },
            "description": "Solo admin. Stesso body e stesse validazioni della creazione: category e mandatory vanno rispediti sempre. 404 se il corso non esiste, 409 se il titolo è già usato da un altro corso."
          }
        },
        {
          "name": "Elimina corso",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["courses", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid del corso" }]
            },
            "description": "Solo admin. 409 se il corso ha assegnazioni collegate: usare Disabilita corso."
          }
        },
        {
          "name": "Disabilita corso",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/courses/:id/disable",
              "host": ["{{baseUrl}}"],
              "path": ["courses", ":id", "disable"],
              "variable": [{ "key": "id", "value": "", "description": "uuid del corso" }]
            },
            "description": "Solo admin. Soft delete: porta active a false."
          }
        }
      ]
    },
    {
      "name": "Assignments",
      "description": "Lettura e completamento sono accessibili a qualsiasi utente autenticato, ma un dipendente vede e completa solo le proprie assegnazioni. Le rotte di gestione (crea, aggiorna, elimina, annulla) richiedono un admin.",
      "item": [
        {
          "name": "Lista assegnazioni",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments?status=assigned&category=Compliance&course_id=&employee_id=&due_month=2026-07",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"],
              "query": [
                { "key": "status", "value": "assigned", "disabled": true, "description": "assigned | completed | expired | cancelled — 'assigned' esclude le scadute, 'expired' restituisce solo quelle" },
                { "key": "category", "value": "Compliance", "disabled": true, "description": "Categoria del corso collegato" },
                { "key": "course_id", "value": "", "disabled": true, "description": "uuid del corso" },
                { "key": "employee_id", "value": "", "disabled": true, "description": "uuid del dipendente — solo admin, ignorato per i dipendenti" },
                { "key": "due_month", "value": "2026-07", "disabled": true, "description": "Mese di scadenza, formato AAAA-MM" }
              ]
            },
            "description": "Filtri tutti opzionali. Stato fuori whitelist, uuid malformato o mese non in formato AAAA-MM: 400. Lo stato 'expired' è derivato in lettura (assigned + scadenza passata), non è mai scritto sul DB."
          }
        },
        {
          "name": "Dettaglio assegnazione",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'assegnazione" }]
            },
            "description": "403 se un dipendente richiede un'assegnazione non sua."
          }
        },
        {
          "name": "Crea assegnazione",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"course_id\": \"\",\n    \"employee_id\": \"\",\n    \"assigned_at\": \"2026-07-14\",\n    \"due_date\": \"2026-09-30\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"]
            },
            "description": "Solo admin. assigned_at è opzionale (default: oggi). Lo stato iniziale è sempre 'assigned'. 400 se il corso è disabilitato o le date non sono coerenti; 409 se il corso è già assegnato a quel dipendente ed è ancora aperto."
          }
        },
        {
          "name": "Aggiorna assegnazione",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"course_id\": \"\",\n    \"employee_id\": \"\",\n    \"assigned_at\": \"2026-07-14\",\n    \"due_date\": \"2026-10-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'assegnazione" }]
            },
            "description": "Solo admin. Lo stato non è modificabile da qui: usare Completa o Annulla. 409 se l'assegnazione è già chiusa."
          }
        },
        {
          "name": "Elimina assegnazione",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'assegnazione" }]
            },
            "description": "Solo admin."
          }
        },
        {
          "name": "Completa assegnazione",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"completed_at\": \"2026-08-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments/:id/complete",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id", "complete"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'assegnazione" }]
            },
            "description": "assigned -> completed. Un dipendente può completare solo le proprie assegnazioni (403 altrimenti). completed_at è opzionale (default: oggi). 409 se l'assegnazione è già chiusa."
          }
        },
        {
          "name": "Annulla assegnazione",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments/:id/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", ":id", "cancel"],
              "variable": [{ "key": "id", "value": "", "description": "uuid dell'assegnazione" }]
            },
            "description": "Solo admin. assigned -> cancelled. 409 se l'assegnazione è già chiusa."
          }
        }
      ]
    },
    {
      "name": "Utility",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verifica che il server sia su. Pubblica."
          }
        }
      ]
    }
  ]
}
